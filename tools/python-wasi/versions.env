# ── Python WASI build version pins ────────────────────────────
# Single source of truth for the CPython + wasi-sdk versions used
# to cross-compile the Python static library for wasm32-wasi.
#
# Pinned separately from tools/pyodide/versions.env because the
# Pyodide build tracks Pyodide upstream (which embeds its own
# CPython fork), while this targets a stock CPython release.

CPYTHON_VERSION="3.13.3"
CPYTHON_MAJOR_MINOR="3.13"

# wasi-sdk provides the clang toolchain and wasi-libc sysroot for
# cross-compiling C code to wasm32-wasi.
WASI_SDK_VERSION="25"
WASI_SDK_MAJOR="25"
