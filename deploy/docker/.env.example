# Environment template for the wasmsh scalable docker-compose stack.
# Copy to `.env` in this directory and edit.  Every var has a sensible
# default built into compose.yml, so a blank .env also works.

# ── Images ────────────────────────────────────────────────────────
# Tag to deploy.  `latest` is always the tip of main (not pinned); for
# production, pin a specific release tag (e.g. 0.6.0) or pin by digest
# from the image-digests.json attached to the corresponding GitHub
# Release — edit compose.yml to replace `:${WASMSH_IMAGE_TAG}` with
# `@sha256:<digest>` for immutable rollouts.
WASMSH_IMAGE_TAG=latest

# ── Dispatcher binding ────────────────────────────────────────────
# host:port published by the dispatcher.  Default is loopback-only.
# For LAN access without a reverse proxy change to `0.0.0.0:8080` —
# note: the dispatcher has no authn, so never put it on a public
# interface without an auth layer (see compose.caddy.yml).
WASMSH_DISPATCHER_BIND=127.0.0.1:8080
RUST_LOG=info

# ── Runner tuning ────────────────────────────────────────────────
# Restore slots per runner pod.  Higher => more concurrent session
# starts per runner; memory scales linearly with WASMSH_WORKER_MAX_*
# below.  Raise from 4 when CPU is plentiful and sessions are short.
WASMSH_RESTORE_SLOTS=4
WASMSH_STARTUP_WARM_RESTORES=2

# V8 heap envelope per session worker (MiB).  Production default is
# 48; the e2e test stack uses 256 to fit the langchain-tests standard
# suite's 10 MiB uploads.  Raise if your workload needs larger
# in-memory Python state.
WASMSH_WORKER_MAX_OLD_GENERATION_MB=48
WASMSH_WORKER_MAX_YOUNG_GENERATION_MB=8

# Broker request/response byte caps (for curl/wget inside the sandbox).
WASMSH_FETCH_BROKER_REQUEST_BYTES=65536
WASMSH_FETCH_BROKER_RESPONSE_BYTES=1048576

# ── Resource limits ──────────────────────────────────────────────
WASMSH_RUNNER_MEMORY_LIMIT=2G
WASMSH_RUNNER_CPU_LIMIT=2
WASMSH_RUNNER_MEMORY_RESERVATION=768M
WASMSH_RUNNER_CPU_RESERVATION=0.25

WASMSH_DISPATCHER_MEMORY_LIMIT=512M
WASMSH_DISPATCHER_CPU_LIMIT=1
WASMSH_DISPATCHER_MEMORY_RESERVATION=128M
WASMSH_DISPATCHER_CPU_RESERVATION=0.1

# ── Caddy overlay (compose.caddy.yml only) ───────────────────────
# Set a real hostname to get automatic Let's Encrypt certs; leave as
# `localhost` to use Caddy's internal CA for local/dev use.
WASMSH_PUBLIC_DOMAIN=localhost
# host:port Caddy binds for HTTPS / HTTP-01 challenge.
WASMSH_HTTPS_BIND=0.0.0.0:443
WASMSH_HTTP_BIND=0.0.0.0:80
# Basic-auth credentials.  Generate a bcrypt hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-password'
# Single-quote the hash value to prevent the shell from eating $ chars.
WASMSH_BASIC_AUTH_USER=wasmsh
WASMSH_BASIC_AUTH_HASH=
