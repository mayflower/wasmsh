lcov.info
*.profraw
*.profdata
proptest-regressions/
/startup/
/.claude/
CLAUDE.md
fuzz/target/
examples/typescript/node_modules/
pkg/

# ── pnpm workspace + adapter packages ──────────────────────────────
node_modules/
packages/npm/*/dist/
packages/npm/*/node_modules/
packages/npm/*/.tsdown/
packages/npm/*/coverage/
packages/npm/*/playwright-report/
packages/npm/*/test-results/
packages/python/langchain-wasmsh/.venv/
packages/python/langchain-wasmsh/.pytest_cache/
packages/python/langchain-wasmsh/uv.lock

# ── Pyodide build outputs staged into the npm package ───────────────
# `tools/pyodide/build-custom.sh` writes the wheel set, pyodide.asm.{js,wasm},
# python_stdlib.zip, etc. into this dir right before `npm publish` packs them
# (see `files` in packages/npm/wasmsh-pyodide/package.json).  Only the small
# bootstrap files needed at install time live in git history.
packages/npm/wasmsh-pyodide/assets/*
!packages/npm/wasmsh-pyodide/assets/micropip-*.whl
!packages/npm/wasmsh-pyodide/assets/packaging-*.whl
!packages/npm/wasmsh-pyodide/assets/sqlite3-*.whl
!packages/npm/wasmsh-pyodide/assets/pyodide-lock.json

# ── Pyodide build outputs staged into the Python runtime wheel ─────
# Mirror of the npm assets dir, packed into the Python wheel.  Build
# outputs (wheels, pyodide.*, generated package.json, lockfile) are
# regenerated by `tools/pyodide/build-custom.sh` per release.
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/*.whl
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/*.zip
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/pyodide.asm.js
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/pyodide.asm.wasm
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/pyodide.js
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/pyodide.mjs
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/pyodide-lock.json
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/package.json

# `assets/lib/*.mjs` are sync'd from `packages/npm/wasmsh-pyodide/lib/`
# by the build script.  The npm side is the source of truth; the python
# mirror is a build-time copy except for `install.mjs` and `node-module.mjs`
# which were committed earlier as bootstrap and remain tracked.
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/allowlist.mjs
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/fetch-helper.mjs
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/protocol.mjs
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/runtime-bridge.mjs
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/node-host-session.mjs
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/snapshot/
packages/python/wasmsh-pyodide-runtime/wasmsh_pyodide_runtime/assets/lib/baseline/

# ── Python packaging build outputs ─────────────────────────────────
packages/python/wasmsh-pyodide-runtime/build/
packages/python/wasmsh-pyodide-runtime/*.egg-info/
**/__pycache__/

# ── npm install output for E2E test fixtures ───────────────────────
e2e/*/node_modules/

# ── Environment files (API keys, secrets) ─────────────────────────
.env

# ── Scalable runner build outputs (local only) ─────────────────────
# Rust and Python WASI toolchain trees materialised by per-tool scripts.
# None of these should ever be committed; they are either cargo `target`
# dirs, downloaded SDK trees, or snapshot artifacts rebuilt per run.
/artifacts/
/dist/pyodide-snapshot/
/dist/pyodide-wasi/
/e2e/pyodide-node/tmp/
/tools/component-host-runner/target/
/tools/pyodide-wasi-host-runner/target/
/tools/python-wasi/build/
/tools/python-wasi/output/
/tools/python-wasi/wasi-sdk/
/tools/pyodide/wasi-build/

# Scratch code-pack for prompt bundling; not a shipped artifact.
/wasmsh-codex-red-green-pack/

# ── Local working notes (kept on disk, never committed) ────────────
# These files are personal planning/reference scratchpads that leaked
# into the tree in earlier commits.  Untracked in a follow-up cleanup
# and re-listed here so they cannot be re-added accidentally.
# `bash.md` in particular paraphrases the GNU Bash manual and must
# stay out of the tree for clean-room provenance (CLAUDE.md rule #4).
/agent_utilities.md
/bash.md
/bash4_implementation_gaps.md
/missing_perf_tuning.md
